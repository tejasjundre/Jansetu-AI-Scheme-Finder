SECRET_KEY=replace-this-in-production
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Prefer DATABASE_URL for managed hosting platforms.
# Example: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Fallback DB fields (used when DATABASE_URL is blank)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=ai_sakhi
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Cache / rate-limit backend
# Example: redis://default:password@host:6379/0
REDIS_URL=
CACHE_DEFAULT_TIMEOUT=300

# Proxy and HTTPS security
USE_X_FORWARDED_HOST=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
CSRF_COOKIE_HTTPONLY=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# Upload limits
DATA_UPLOAD_MAX_MEMORY_SIZE=4194304
FILE_UPLOAD_MAX_MEMORY_SIZE=2097152

# App safeguards
RATE_LIMIT_ENABLED=True
RATE_LIMIT_WINDOW_SECONDS=60
AUDIT_LOG_READ_REQUESTS=False

# News refresh behavior
NEWS_FETCH_ENABLED=True
NEWS_FETCH_TIMEOUT_SECONDS=4
NEWS_CACHE_SECONDS=1800
STALE_NEWS_CACHE_SECONDS=86400

# Optional ops webhook alerts (Slack/Teams/Discord compatible webhook URL)
ALERT_WEBHOOK_URL=
